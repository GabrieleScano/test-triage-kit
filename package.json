{
  "name": "test-triage-kit",
  "version": "1.0.0",
  "description": "Failure triage toolkit for Playwright: classifies test failures, deduplicates them by fingerprint, detects flakiness from run history, and generates AI-enriched bug reports.",
  "type": "module",
  "bin": {
    "triage": "dist/cli.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./reporter": "./dist/reporter.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "start": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts fixtures/sample-report.json --out triage-output --history triage-output/history.json",
    "demo:enriched": "tsx scripts/demo-enriched.ts",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "keywords": [
    "qa",
    "playwright",
    "triage",
    "bug-report",
    "flaky-tests",
    "ai",
    "testing"
  ],
  "author": "Gabriele Scano",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
