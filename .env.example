# Optional — enables the AI enrichment layer
ANTHROPIC_API_KEY=

# Optional — used by --github (provided automatically in GitHub Actions)
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo

# Optional — used by --jira (works against the free tier of Jira Cloud)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Optional — used by --slack
SLACK_WEBHOOK_URL=
